# Copy to `.env` and edit. Every NETSENTRY_ variable overrides config; nested
# keys use a double-underscore delimiter. `.env` is gitignored — never commit it.

# Global seed (reproducibility).
# NETSENTRY_SEED=42

# Where to fetch CIC-IDS2017 from (a mirror you are licensed to use). If unset,
# place the CSVs in data/raw/ manually, or use synthetic data for demos.
# NETSENTRY_DATA__SOURCE_URL=

# MLflow tracking server (defaults to a local ./mlruns file store if unset).
# NETSENTRY_MLFLOW__TRACKING_URI=http://localhost:5000

# Serving.
# NETSENTRY_SERVING__PORT=8000
# NETSENTRY_SERVING__DEFAULT_THRESHOLD_PROFILE=fpr_0.1pct

# Emit JSON logs (1/true) instead of console format.
# NETSENTRY_LOG_JSON=0
